# Netacad credentials
NETACAD_EMAIL=your@email.com
NETACAD_PASSWORD=yourpassword

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# Bot behaviour
HEADLESS=false        # true = no visible browser window
DELAY_MIN=1.0         # min seconds between actions (human-like)
DELAY_MAX=3.0         # max seconds between actions
